{
  "manifest_version": 3,
  "name": "Discord Voice Recorder",
  "version": "1.0.0",
  "description": "Adds a voice recording button to Discord for quick audio messages",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://discord.com/*", "https://*.discord.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
